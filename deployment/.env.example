DOMAIN=flowbon.votredomaine.com

# ─── Base de Données PostgreSQL ───────────────────────────────────────────────
# IMPORTANT : Utiliser un mot de passe fort et unique en production.
DB_USER=flowbon
DB_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT
DB_NAME=flowbon

# ─── Sécurité JWT ────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
# OU             openssl rand -hex 32
SECRET_KEY=CHANGEZ_MOI_CLE_SECRETE_JWT_TRES_LONGUE_ET_ALEATOIRE

# ─── Durée de Session (JWT) ──────────────────────────────────────────────────
# Temps avant déconnexion automatique en cas de fermeture de l'onglet/navigateur
# Jeton d'accès (recommandé : 15 min pour maximiser la sécurité)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Jeton de rafraîchissement (recommandé : 7 jours, ou 1 jour pour une sécurité stricte)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Images Docker (depuis votre registre) ───────────────────────────────────
BACKEND_IMAGE=flowbon/backend:latest
FRONTEND_IMAGE=flowbon/frontend:latest

# ─── Configuration E-mail (SMTP) ─────────────────────────────────────────────
# Option 1 : Gmail (générer un "App Password" dans les paramètres Google)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-app-password-gmail

# Option 2 : SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.votre_cle_api_sendgrid
